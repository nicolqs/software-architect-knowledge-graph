# Copy to .env and fill in. Never commit .env.

# --- LLM providers ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Agent model routing (see plan / cost guardrails)
AGENT_MODEL_DEFAULT=claude-sonnet-4-6
AGENT_MODEL_ARCHITECT=claude-opus-4-7
EMBEDDING_MODEL=text-embedding-3-large

# Cost guardrails
DAILY_COST_LIMIT_USD=20
INGEST_COST_LIMIT_USD=5

# --- Neo4j ---
# Host ports — override these if you have another Neo4j running locally.
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme-neo4j

# --- Postgres (project memory + pgvector) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=architect
POSTGRES_USER=architect
POSTGRES_PASSWORD=changeme-postgres

# --- Langfuse (self-hosted by default) ---
LANGFUSE_PORT=3001
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_SECRET=changeme-langfuse-encryption-key-min-32-chars

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# --- Web ---
VITE_API_URL=http://localhost:8000
